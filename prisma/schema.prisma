generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  driver
  admin
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  refreshToken String?

  role Role @default(user)

  drivers Driver[]
  rides   Ride[]

  reviews   Review[]     
  complaints Complaint[] 

  emailOtp        String?
  emailOtpExpires DateTime?
  isVerified      Boolean   @default(false)

  createdAt DateTime @default(now())
}

model VehicleCategory {
  id        String @id @default(uuid())
  name      String 
  baseFare  Float
  perKmRate Float
  capacity  Int

  drivers Driver[]
  rides   Ride[]
  reviews Review[] 

  createdAt DateTime @default(now())
}

model Driver {
  id          String  @id @default(uuid())
  driverName  String
  numberPlate String?
  vehicleName String 

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rides Ride[]

  reviews   Review[]   
  complaints Complaint[]

  latitude  Float
  longitude Float

  isOnline Boolean @default(true)

  rating      Float   @default(0)
  driverImage String?

  adharUrl String?   
  address   String? 

  categoryId String
  category   VehicleCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
}

enum RideStatus {
  pending
  ongoing
  complete
  cancelled
}

model Ride {
  id String @id @default(uuid())

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   VehicleCategory @relation(fields: [categoryId], references: [id])

  reviews Review[] 

  status RideStatus @default(pending)

  otp        String?
  otpExpiry  DateTime?
  isVerified Boolean   @default(false)

  pickup      String
  destination String

  pickupLatitude           Float?
  pickupLongitude          Float?
  destinationLatitude      Float?
  destinationLongitude     Float?
  estimatedDistanceKm      Float?
  estimatedDurationMinutes Int?

  estimatedFare Float?

  createdAt DateTime @default(now())
}

enum ReviewReason {
  extra_money_demand
  wrong_pickup
  rude_behavior
  unsafe_driving
  driving_on_call
  vehicle_not_clean
  late_arrival
  route_issue
  other
}

model Review {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id])

  rideId String @unique   
  ride   Ride @relation(fields: [rideId], references: [id])

  categoryId String
  category   VehicleCategory @relation(fields: [categoryId], references: [id])

  rating Int

  reason  ReviewReason
  // comment String?

  createdAt DateTime @default(now())
}

model Complaint {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  message String
  status  String @default("pending") // pending, resolved

  createdAt DateTime @default(now())
}

